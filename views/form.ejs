<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <title>放映宣传资料生成器</title>
    <link rel="stylesheet" href="/style.css">
    <style>
        .movie-block { border: 1px solid #ccc; padding: 10px; margin-bottom: 10px; }
        .movie-block h3 { margin-top: 0; }
        .add-movie-btn { margin: 10px 0; }
    </style>
</head>
<body>
    <h1>放映宣传资料生成器</h1>
    <form id="mainForm" method="POST" action="/generate">
        <label>电影周周数：<input type="text" name="week" required></label><br>
        <label>主讲人：<input type="text" name="speaker" required></label><br>
        <label>主题：<input type="text" name="theme" required></label><br>
        <label>一句对主题的阐释：<input type="text" name="themeDesc" required></label><br>
        <label>放映安排：<textarea name="schedule" rows="4" cols="50" required></textarea></label><br>
        <div id="movies">
            <!-- 动态添加电影信息块 -->
        </div>
        <button type="button" class="add-movie-btn" onclick="addMovie()">添加电影</button><br>
        <button type="submit">生成 HTML/Word</button>
    </form>
    <script>
        let movieIndex = 0;
        function addMovie() {
            const moviesDiv = document.getElementById('movies');
            const div = document.createElement('div');
            div.className = 'movie-block';
            div.innerHTML = `
                <h3>电影信息</h3>
                <label>放映周几：<input type="text" name="movies[${movieIndex}][day]" placeholder="如 周五" required></label><br>
                <label>是否为沙龙周：<input type="checkbox" name="movies[${movieIndex}][isSalon]" onchange="toggleSalonFields(this, ${movieIndex})"></label><br>
                <label>中文名：<input type="text" name="movies[${movieIndex}][chinese]" required></label><br>
                <label>外文名：<input type="text" name="movies[${movieIndex}][foreign]" required></label><br>
                <label>年份：<input type="text" name="movies[${movieIndex}][year]" required></label><br>
                <label>导演：<input type="text" name="movies[${movieIndex}][director]" required></label><br>
                <label>编剧：<input type="text" name="movies[${movieIndex}][writer]" required></label><br>
                <label>主演：<input type="text" name="movies[${movieIndex}][actors]" required></label><br>
                <label>类型：<input type="text" name="movies[${movieIndex}][genre]" required></label><br>
                <label>制片地区/国家：<input type="text" name="movies[${movieIndex}][region]" required></label><br>
                <label>片长：<input type="text" name="movies[${movieIndex}][length]" required></label><br>
                <label>豆瓣评分：<input type="text" name="movies[${movieIndex}][douban]" required></label><br>
                <label>剧情简介：<textarea name="movies[${movieIndex}][desc]" rows="3" cols="40" required></textarea></label><br>
                <label>豆瓣短评：<textarea name="movies[${movieIndex}][short]" rows="2" cols="40"></textarea></label><br>
                <div id="salonFields${movieIndex}" style="display:none">
                  <label>沙龙台词：<input type="text" name="movies[${movieIndex}][salon_quote]"></label><br>
                  <label>沙龙导赏段落1：<textarea name="movies[${movieIndex}][salon_intro1]" rows="2" cols="40"></textarea></label><br>
                  <label>沙龙导赏段落2：<textarea name="movies[${movieIndex}][salon_intro2]" rows="2" cols="40"></textarea></label><br>
                </div>
                <button type="button" onclick="this.parentNode.remove()">删除本电影</button>
            `;
            moviesDiv.appendChild(div);
            movieIndex++;
        }
        function toggleSalonFields(checkbox, idx) {
            document.getElementById('salonFields'+idx).style.display = checkbox.checked ? '' : 'none';
        }
    </script>
</body>
</html> 