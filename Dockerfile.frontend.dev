# 前端开发环境 Dockerfile
FROM node:20-alpine

WORKDIR /app

# 复制依赖文件
COPY package*.json ./
COPY tsconfig*.json ./
COPY vite.config.ts ./
COPY eslint.config.js ./

# 安装依赖
RUN npm ci

# 复制源代码（通过 volumes 挂载，这里仅作备份）
COPY index.html ./
COPY src ./src
COPY public ./public

# 启动开发服务器
CMD ["npm", "run", "dev", "--", "--host"]
